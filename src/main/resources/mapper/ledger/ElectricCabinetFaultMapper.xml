                </if>
            </if>
            <if test="ecfChecker != null and ecfChecker != ''">
                AND ecf_checker LIKE CONCAT('%', #{ecfChecker}, '%')
            </if>
            <if test="ecfFaultType != null and ecfFaultType != ''">
                AND ecf_fault_type LIKE CONCAT('%', #{ecfFaultType}, '%')
