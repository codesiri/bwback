<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.youlai.boot.ledger.mapper.ElectricCabinetInspectionMapper">

    <!-- 获取抽屉柜检修试验记录分页列表 -->
    <select id="getElectricCabinetInspectionPage" resultType="com.youlai.boot.ledger.model.vo.ElectricCabinetInspectionVO">
        SELECT
                id,
                eci_report_no,
                eci_inspect_date,
                eci_inspect_unit,
                eci_inspect_person,
                eci_inspect_type,
                eci_inspect_item,
                eci_test_data,
                eci_standard,
                eci_result,
                eci_rectify_content,
                eci_recheck_result,
                eci_factory,
                eci_reserve_1,
                eci_reserve_2,
                eci_reserve_3
        FROM
            electric_cabinet_inspection
        <where>
            <if test="queryParams.eciReportNo != null and queryParams.eciReportNo != ''">
                AND eci_report_no LIKE CONCAT('%', #{queryParams.eciReportNo}, '%')
            </if>
            <if test="queryParams.eciInspectDate != null">
                <if test="queryParams.eciInspectDate[0] != null and queryParams.eciInspectDate[0] != ''">
                    <bind name="startDate" value="queryParams.eciInspectDate[0].length() == 10 ? queryParams.eciInspectDate[0] + ' 00:00:00' : queryParams.eciInspectDate[0]"/>
                    AND eci_inspect_date &gt;= #{startDate}
                </if>
                <if test="queryParams.eciInspectDate[1] != null and queryParams.eciInspectDate[1] != ''">
                    <bind name="endDate" value="queryParams.eciInspectDate[1].length() == 10 ? queryParams.eciInspectDate[1] + ' 23:59:59' : queryParams.eciInspectDate[1]"/>
                    AND eci_inspect_date &lt;= #{endDate}
                </if>
            </if>
            <if test="queryParams.eciInspectUnit != null and queryParams.eciInspectUnit != ''">
                AND eci_inspect_unit LIKE CONCAT('%', #{queryParams.eciInspectUnit}, '%')
            </if>
            <if test="queryParams.eciInspectPerson != null and queryParams.eciInspectPerson != ''">
                AND eci_inspect_person LIKE CONCAT('%', #{queryParams.eciInspectPerson}, '%')
            </if>
            <if test="queryParams.eciInspectType != null and queryParams.eciInspectType != ''">
                AND eci_inspect_type LIKE CONCAT('%', #{queryParams.eciInspectType}, '%')
            </if>
            <if test="queryParams.eciInspectItem != null and queryParams.eciInspectItem != ''">
                AND eci_inspect_item LIKE CONCAT('%', #{queryParams.eciInspectItem}, '%')
            </if>
            <if test="queryParams.eciTestData != null and queryParams.eciTestData != ''">
                AND eci_test_data LIKE CONCAT('%', #{queryParams.eciTestData}, '%')
            </if>
            <if test="queryParams.eciStandard != null and queryParams.eciStandard != ''">
                AND eci_standard LIKE CONCAT('%', #{queryParams.eciStandard}, '%')
            </if>
            <if test="queryParams.eciFactory != null and queryParams.eciFactory != ''">
                AND eci_factory LIKE CONCAT('%', #{queryParams.eciFactory}, '%')
            </if>
        </where>
    </select>

    <!-- 获取抽屉柜检修试验记录分页列表 -->
    <select id="exportElectricCabinetInspections" resultType="com.youlai.boot.ledger.model.vo.ElectricCabinetInspectionVO">
        SELECT
        id,
        eci_report_no,
        eci_inspect_date,
        eci_inspect_unit,
        eci_inspect_person,
        eci_inspect_type,
        eci_inspect_item,
        eci_test_data,
        eci_standard,
        eci_result,
        eci_rectify_content,
        eci_recheck_result,
        eci_factory,
        eci_reserve_1,
        eci_reserve_2,
        eci_reserve_3
        FROM
        electric_cabinet_inspection
        <where>
            <if test="eciReportNo != null and eciReportNo != ''">
                AND eci_report_no LIKE CONCAT('%', #{eciReportNo}, '%')
            </if>
            <if test="eciInspectDate != null">
                <if test="eciInspectDate[0] != null and eciInspectDate[0] != ''">
                    <bind name="startDate" value="eciInspectDate[0].length() == 10 ? eciInspectDate[0] + ' 00:00:00' : eciInspectDate[0]"/>
                    AND eci_inspect_date &gt;= #{startDate}
                </if>
                <if test="eciInspectDate[1] != null and eciInspectDate[1] != ''">
                    <bind name="endDate" value="eciInspectDate[1].length() == 10 ? eciInspectDate[1] + ' 23:59:59' : eciInspectDate[1]"/>
                    AND eci_inspect_date &lt;= #{endDate}
                </if>
            </if>
            <if test="eciInspectUnit != null and eciInspectUnit != ''">
                AND eci_inspect_unit LIKE CONCAT('%', #{eciInspectUnit}, '%')
            </if>
            <if test="eciInspectPerson != null and eciInspectPerson != ''">
                AND eci_inspect_person LIKE CONCAT('%', #{eciInspectPerson}, '%')
            </if>
            <if test="eciInspectType != null and eciInspectType != ''">
                AND eci_inspect_type LIKE CONCAT('%', #{eciInspectType}, '%')
            </if>
            <if test="eciInspectItem != null and eciInspectItem != ''">
                AND eci_inspect_item LIKE CONCAT('%', #{eciInspectItem}, '%')
            </if>
            <if test="eciTestData != null and eciTestData != ''">
                AND eci_test_data LIKE CONCAT('%', #{eciTestData}, '%')
            </if>
            <if test="eciStandard != null and eciStandard != ''">
                AND eci_standard LIKE CONCAT('%', #{eciStandard}, '%')
            </if>
            <if test="eciFactory != null and eciFactory != ''">
                AND eci_factory LIKE CONCAT('%', #{eciFactory}, '%')
            </if>
        </where>
    </select>

</mapper>
