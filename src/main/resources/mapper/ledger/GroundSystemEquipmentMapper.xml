            <if test="gseInstallDate != null">
                <if test="gseInstallDate[0] != null and gseInstallDate[0] != ''">
                    <bind name="startDate" value="gseInstallDate[0].length() == 10 ? gseInstallDate[0] + ' 00:00:00' : gseInstallDate[0]"/>
                    AND gse_install_date &gt;= #{startDate}
                </if>
                <if test="gseInstallDate[1] != null and gseInstallDate[1] != ''">
                    <bind name="endDate" value="gseInstallDate[1].length() == 10 ? gseInstallDate[1] + ' 23:59:59' : gseInstallDate[1]"/>
                    AND gse_install_date &lt;= #{endDate}
                </if>
            </if>
            <if test="gseStatus != null and gseStatus != ''">
                AND gse_status = #{gseStatus}
            </if>
            <if test="gseFactory != null and gseFactory != ''">
                AND gse_factory LIKE CONCAT('%', #{gseFactory}, '%')
            </if>
        </where>
    </select>

</mapper>
